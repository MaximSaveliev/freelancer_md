PORT=8004

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # from: stripe listen --forward-to localhost:8004/webhooks/stripe

# Stripe Price IDs — create products/prices in the Stripe Dashboard, paste IDs here
STRIPE_PRO_PRICE_ID_USD=price_...
STRIPE_PRO_PRICE_ID_EUR=price_...
STRIPE_PRO_PRICE_ID_MDL=price_...
STRIPE_PREMIUM_PRICE_ID_USD=price_...
STRIPE_PREMIUM_PRICE_ID_EUR=price_...
STRIPE_PREMIUM_PRICE_ID_MDL=price_...

# Frontend base URL (used for Stripe redirect URLs)
BASE_URL=http://localhost:3000

# Supabase (cloud-hosted)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_KEY=your_service_role_key

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Redis Cloud
REDIS_URL=redis://default:<password>@<host>:<port>
