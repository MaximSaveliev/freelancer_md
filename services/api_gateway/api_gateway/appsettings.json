{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=auth_db;Username=auth_admin;Password=auth_admin"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "admin",
    "Password": "admin",
    "VirtualHost": "/",
    "Exchange": ""
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "bl": {
        "ClusterId": "bl",
        "Match": { "Path": "/v1/api/bl/{**rest}" },
        "Transforms": [ { "PathRemovePrefix": "/v1/api/bl" } ]
      },
      "payment": {
        "ClusterId": "payment",
        "Match": { "Path": "/v1/api/payment/{**rest}" },
        "Transforms": [ { "PathRemovePrefix": "/v1/api/payment" } ]
      },
      "messenger": {
        "ClusterId": "messenger",
        "Match": { "Path": "/v1/api/messenger/{**rest}" },
        "Transforms": [ { "PathRemovePrefix": "/v1/api/messenger" } ]
      }
    },
    "Clusters": {
      "bl":        { "Destinations": { "main": { "Address": "http://bl:8001" } } },
      "payment":   { "Destinations": { "main": { "Address": "http://payment:8004" } } },
      "messenger": { "Destinations": { "main": { "Address": "http://messenger:8088" } } }
    }
  }
}
